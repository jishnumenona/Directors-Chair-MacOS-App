      "package": "DirectorsChairCore",
      "gate": true
    },
    {
      "id": "services",
      "name": "Services (auth \u00b7 sync \u00b7 AI clients)",
      "component": "desktop",
      "kind": "spm",
      "package": "DirectorsChairServices",
      "gate": true
    },
    {
      "id": "production",
      "name": "Production (schedule \u00b7 budget \u00b7 cast/crew)",
      "component": "desktop",
      "kind": "spm",
      "package": "DirectorsChairProduction",
      "gate": true
    },
    {
      "id": "views",
      "name": "Views (creative \u00b7 timeline \u00b7 snapshots)",
      "component": "desktop",
      "kind": "spm",
      "package": "DirectorsChairViews",
      "gate": true
    },
    {
      "id": "exports",
      "name": "Exports (FDX \u00b7 Fountain \u00b7 PDF \u00b7 CSV)",
      "component": "desktop",
      "kind": "spm",
      "package": "DirectorsChairExports",
      "gate": true
    },
    {
      "id": "app",
      "name": "App target (unit \u00b7 adapters)",
      "component": "desktop",
