{
  "description": "Pluggable suite registry consumed by run-qa.sh. Each suite maps to a build/test invocation. `component` ties results back to a catalog. `gate` suites must pass for the run to be releasable; `advisory` suites report without blocking. Adding a server later = one new entry, no orchestrator change.",
  "suites": [
    {
      "id": "core",
      "name": "Core (models · persistence)",
      "component": "desktop",
      "kind": "spm",
      "package": "DirectorsChairCore",
      "gate": true
    },
    {
      "id": "services",
      "name": "Services (auth · sync · AI clients)",
      "component": "desktop",
      "kind": "spm",
      "package": "DirectorsChairServices",
      "gate": true
    },
    {
      "id": "production",
      "name": "Production (schedule · budget · cast/crew)",
      "component": "desktop",
      "kind": "spm",
      "package": "DirectorsChairProduction",
      "gate": true
    },
    {
      "id": "views",
      "name": "Views (creative · timeline · snapshots)",
      "component": "desktop",
      "kind": "spm",
      "package": "DirectorsChairViews",
      "gate": true
    },
    {
      "id": "exports",
      "name": "Exports (FDX · Fountain · PDF · CSV)",
      "component": "desktop",
      "kind": "spm",
      "package": "DirectorsChairExports",
      "gate": true
    },
    {
      "id": "app",
      "name": "App target (unit · adapters)",
      "component": "desktop",
      "kind": "xcodebuild",
      "scheme": "DirectorsChair-Desktop",
      "gate": true
    },
    {
      "id": "ui-e2e",
      "name": "UI end-to-end (XCUITest)",
      "component": "desktop",
      "kind": "xcodebuild-ui",
      "scheme": "DirectorsChair-UITests",
      "gate": false,
      "notes": "Advisory until the UI-automation environment is stabilized (see qa/README.md §Known limitations). Drives real user workflows against the deterministic QA fixture."
    }
  ]
}
