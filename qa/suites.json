    {
      "id": "ui-e2e",
      "name": "UI end-to-end (XCUITest)",
      "component": "desktop",
      "kind": "xcodebuild-ui",
      "scheme": "DirectorsChair-UITests",
      "gate": true,
      "notes": "End-to-end user workflows against the deterministic QA fixture. Made reliable via offline test mode (no auth gate, no network, no global key monitors, no splash). Two consecutive clean 11/11 runs."
